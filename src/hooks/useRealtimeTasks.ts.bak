"use client";

import { useEffect, useState, useCallback, useRef } from "react";
import { createClient } from "@/lib/supabase/client";
import type { RealtimeChannel } from "@supabase/supabase-js";

// ─────────────────────────────────────────────────────────────────────────────
// Types
// ─────────────────────────────────────────────────────────────────────────────

export type Priority = "HIGH" | "MEDIUM" | "LOW";

export interface Task {
  id: string;
  title: string;
  description: string | null;
  priority: Priority;
  is_completed: boolean;
  due_date: string | null;
  position: number;
  tags: string[];
  task_list_id: string;
  assignee_id: string | null;
  creator_id: string;
  created_at: string;
  updated_at: string;
}

interface UseRealtimeTasksOptions {
  /** The TaskList ID to subscribe to */
  listId: string;
  /** Callback fired when any change occurs (INSERT / UPDATE / DELETE) */
  onError?: (error: Error) => void;
}

interface UseRealtimeTasksReturn {
  tasks: Task[];
  isLoading: boolean;
  error: Error | null;
  /** Manually refresh tasks from the database */
  refetch: () => Promise<void>;
}

type RealtimeEventType = "INSERT" | "UPDATE" | "DELETE";

// ─────────────────────────────────────────────────────────────────────────────
// Hook
// ─────────────────────────────────────────────────────────────────────────────

/**
 * useRealtimeTasks
 *
 * Subscribes to real-time changes on the `tasks` table for a given listId.
 * Handles INSERT, UPDATE, and DELETE events optimistically so collaborators
 * see changes instantly without full re-fetches.
 */
export function useRealtimeTasks({
  listId,
  onError,
}: UseRealtimeTasksOptions): UseRealtimeTasksReturn {
  const supabase = createClient();

  const [tasks, setTasks] = useState<Task[]>([]);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  // Keep a stable ref to the channel so we can clean up on unmount / listId change
  const channelRef = useRef<RealtimeChannel | null>(null);

  // ── Initial fetch ──────────────────────────────────────────────────────────

  const fetchTasks = useCallback(async () => {
    setIsLoading(true);
    setError(null);

    const { data, error: fetchError } = await supabase
      .from("tasks")
      .select("*")
      .eq("task_list_id", listId)
      .order("position", { ascending: true });

    if (fetchError) {
      const err = new Error(fetchError.message);
      setError(err);
      onError?.(err);
    } else {
      setTasks((data as Task[]) ?? []);
    }

    setIsLoading(false);
  }, [listId, supabase, onError]);

  // ── Realtime handlers (optimistic state updates) ───────────────────────────

  const handleInsert = useCallback((newTask: Task) => {
    setTasks((prev) => {
      // Guard against duplicates
      if (prev.some((t) => t.id === newTask.id)) return prev;
      // Insert at correct position
      const next = [...prev, newTask];
      return next.sort((a, b) => a.position - b.position);
    });
  }, []);

  const handleUpdate = useCallback((updatedTask: Task) => {
    setTasks((prev) =>
      prev
        .map((t) => (t.id === updatedTask.id ? { ...t, ...updatedTask } : t))
        .sort((a, b) => a.position - b.position)
    );
  }, []);

  const handleDelete = useCallback(
    (deletedRecord: Pick<Task, "id">) => {
      setTasks((prev) => prev.filter((t) => t.id !== deletedRecord.id));
    },
    []
  );

  // ── Subscription setup ─────────────────────────────────────────────────────

  useEffect(() => {
    if (!listId) return;

    // Initial fetch
    fetchTasks();

    // Tear down any existing channel before creating a new one
    if (channelRef.current) {
      supabase.removeChannel(channelRef.current);
    }

    const channelName = `tasks:list=${listId}`;

    const channel = supabase
      .channel(channelName)
      .on<Task>(
        "postgres_changes",
        {
          event: "*" as RealtimeEventType,
          schema: "public",
          table: "tasks",
          filter: `task_list_id=eq.${listId}`,
        },
        (payload) => {
          switch (payload.eventType) {
            case "INSERT":
              handleInsert(payload.new as Task);
              break;
            case "UPDATE":
              handleUpdate(payload.new as Task);
              break;
            case "DELETE":
              // payload.old only contains the primary key by default
              handleDelete(payload.old as Pick<Task, "id">);
              break;
          }
        }
      )
      .subscribe((status, subscribeError) => {
        if (status === "CHANNEL_ERROR" || subscribeError) {
          const err = new Error(
            subscribeError?.message ?? "Realtime subscription failed"
          );
          setError(err);
          onError?.(err);
        }
      });

    channelRef.current = channel;

    return () => {
      supabase.removeChannel(channel);
      channelRef.current = null;
    };
  }, [listId]); // Re-subscribe when listId changes

  return {
    tasks,
    isLoading,
    error,
    refetch: fetchTasks,
  };
}
